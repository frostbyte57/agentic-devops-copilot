{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "CopilotReadOnly",
      "Effect": "Allow",
      "Action": [
        "logs:Describe*",
        "logs:Get*",
        "logs:List*",
        "logs:FilterLogEvents",
        "logs:StartQuery",
        "logs:StopQuery",
        "cloudwatch:Describe*",
        "cloudwatch:Get*",
        "cloudwatch:List*",
        "ecs:Describe*",
        "ecs:List*",
        "elasticloadbalancing:Describe*"
      ],
      "Resource": "*"
    }
  ]
}
