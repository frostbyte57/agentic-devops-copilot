# ── LLM provider ───────────────────────────────────────────────────────────
# Switch the whole copilot between paid APIs and a model on your laptop.
#   anthropic  paid  (default)   — needs ANTHROPIC_API_KEY
#   openai     paid              — needs OPENAI_API_KEY,  pip install '.[openai]'
#   local      free, on-device   — Ollama/LM Studio/vLLM, pip install '.[local]'
COPILOT_PROVIDER=anthropic

# Anthropic (paid)
ANTHROPIC_API_KEY=sk-ant-...
# Optional model overrides (defaults: opus-4-8 reasoning / sonnet-4-6 fast):
# COPILOT_ANTHROPIC_REASONING_MODEL=claude-opus-4-8
# COPILOT_ANTHROPIC_FAST_MODEL=claude-sonnet-4-6

# OpenAI (paid) — set COPILOT_PROVIDER=openai to use these
# OPENAI_API_KEY=sk-...
# COPILOT_OPENAI_REASONING_MODEL=gpt-4o
# COPILOT_OPENAI_FAST_MODEL=gpt-4o-mini

# Local model (free) — set COPILOT_PROVIDER=local. Start your server first, e.g.
#   ollama pull llama3.1 && ollama serve
# Default endpoint is Ollama's; LM Studio uses :1234/v1, vLLM uses :8000/v1.
# COPILOT_LOCAL_BASE_URL=http://localhost:11434/v1
# COPILOT_LOCAL_REASONING_MODEL=llama3.1
# COPILOT_LOCAL_FAST_MODEL=llama3.1
# COPILOT_LOCAL_API_KEY=not-needed

# AWS (standard credential chain is used; these are optional overrides)
AWS_PROFILE=default
AWS_REGION=us-east-1
# Optional: a dedicated read-only role the copilot assumes
COPILOT_READONLY_ROLE_ARN=

# Optional GitHub (for the deploy-diff node)
GITHUB_TOKEN=
GITHUB_REPO=owner/repo
